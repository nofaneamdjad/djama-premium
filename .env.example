# ═══════════════════════════════════════════════════════════════
# DJAMA Premium — Variables d'environnement requises
# Copier ce fichier en .env.local et remplir chaque valeur.
# NE JAMAIS commiter .env.local dans git.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
# Récupérables dans : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SUPABASE_SERVICE_ROLE_KEY

# ── Admin DJAMA ───────────────────────────────────────────────
# Mot de passe de l'espace admin (min. 32 caractères recommandés)
# Générer avec : openssl rand -base64 32
ADMIN_PASS=VOTRE_MOT_DE_PASSE_ADMIN_TRES_SECRET

# ── Resend (emails transactionnels) ──────────────────────────
# Récupérable dans : resend.com > API Keys
RESEND_API_KEY=VOTRE_RESEND_API_KEY
RESEND_FROM=DJAMA <noreply@djama.space>
CONTACT_EMAIL=admin@djama.space

# ── Stripe ───────────────────────────────────────────────────
# Récupérables dans : dashboard.stripe.com > Developers > API Keys
# Format production  : sk_live_...   |  Format test : sk_test_...
STRIPE_SECRET_KEY=VOTRE_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=VOTRE_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_COACHING_IA_PRICE_ID=price_...
# Clé publique (bundlée côté client — utiliser pk_live_ ou pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# URL du Billing Portal Stripe (dashboard.stripe.com > Billing > Customer portal)
NEXT_PUBLIC_STRIPE_PORTAL_URL=https://billing.stripe.com/p/login/...

# ── PayPal ───────────────────────────────────────────────────
# Récupérables dans : developer.paypal.com > Apps & Credentials
PAYPAL_CLIENT_ID=VOTRE_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=VOTRE_PAYPAL_CLIENT_SECRET
PAYPAL_PLAN_ID=VOTRE_PAYPAL_PLAN_ID
PAYPAL_WEBHOOK_ID=VOTRE_PAYPAL_WEBHOOK_ID
# "sandbox" pour les tests, "live" pour la production
PAYPAL_MODE=sandbox

# ── Anthropic (IA) ────────────────────────────────────────────
# Récupérable dans : console.anthropic.com > API Keys
ANTHROPIC_API_KEY=VOTRE_ANTHROPIC_API_KEY

# ── Web Push (notifications push) ────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=VOTRE_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=VOTRE_VAPID_PRIVATE_KEY
VAPID_EMAIL=admin@djama.space

# ── Planification (notifications internes) ───────────────────
NOTIFY_FROM_EMAIL=noreply@djama.fr
NOTIFY_TO_EMAIL=admin@djama.space

# ── CRON (tâches planifiées) ──────────────────────────────────
# Secret pour sécuriser les endpoints cron Vercel
CRON_SECRET=VOTRE_CRON_SECRET_LONG_ET_ALEATOIRE

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://djama.space

# ── Options de développement ─────────────────────────────────
# Liste d'emails autorisés à accéder au Coaching IA sans paiement (dev uniquement)
# NEXT_PUBLIC_COACHING_DEV_EMAILS=dev@example.com,test@example.com
# Bypass l'authentification Coaching IA en dev (true/false)
# NEXT_PUBLIC_DEV_BYPASS_COACHING=false
